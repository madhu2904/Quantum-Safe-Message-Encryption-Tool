<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.Cursor?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.ComboBox?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TextArea?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.text.Font?>

<BorderPane style="-fx-background-color: linear-gradient(to bottom right, #f3e8ff, #e9d8fd);" xmlns="http://javafx.com/javafx/25" xmlns:fx="http://javafx.com/fxml/1" fx:controller="org.quantum_safe.client_quantum.Controller.DashboardController">

    <!-- TOP SECTION -->
    <top>
        <HBox alignment="CENTER_LEFT" prefWidth="674.0" spacing="20" style="-fx-padding: 20;">
            <Label fx:id="welcomeLabel" style="-fx-font-size: 28px;" text="QUANTUM SAFE MESSAGE APPLICATION" textFill="#3e217b">
            <font>
               <Font name="Arial" size="30.0" />
            </font></Label>

            <!-- Spacer to push logout right -->
            <Region HBox.hgrow="ALWAYS" />

            <Button fx:id="logoutButton" prefHeight="34.0" prefWidth="80.0" style="-fx-background-radius: 8; -fx-background-color: #FF7276;;" text="Logout">
            <font>
               <Font name="Arial" size="15.0" />
            </font>
            <cursor>
               <Cursor fx:constant="HAND" />
            </cursor></Button>
         <cursor>
            <Cursor fx:constant="HAND" />
         </cursor>
        </HBox>
    </top>

    <!-- CENTER SECTION -->
    <center>
        <VBox alignment="CENTER" fillWidth="true" spacing="25" style="-fx-padding: 40;">

            <!-- TO Row -->
            <HBox alignment="CENTER_LEFT" spacing="15">
                <Label text="To:">
               <font>
                  <Font size="15.0" />
               </font></Label>

                <ComboBox fx:id="recipientComboBox" editable="true" maxWidth="Infinity" promptText="Type or select Mail ID" style="-fx-background-color: #FFFFE0;" HBox.hgrow="ALWAYS">
               <cursor>
                  <Cursor fx:constant="HAND" />
               </cursor></ComboBox>
                <cursor>
                  <Cursor fx:constant="HAND" />
               </cursor>
            </HBox>

            <!-- Message Area -->
            <TextArea fx:id="messageArea" maxWidth="Infinity" promptText="Type your message..." style="-fx-border-radius: 20;                  -fx-background-radius: 20;                  -fx-background-color: #FFFFE0;                  -fx-text-fill: #3e217b;" wrapText="true" VBox.vgrow="ALWAYS">
            <cursor>
               <Cursor fx:constant="TEXT" />
            </cursor>
            <font>
               <Font name="Arial" size="15.0" />
            </font></TextArea>

            <!-- Buttons Row -->
            <HBox alignment="CENTER" spacing="40">

                <Button fx:id="sendButton" style="-fx-background-color: #90ee90;" text="Send">
               <font>
                  <Font name="Arial" size="15.0" />
               </font>
               <cursor>
                  <Cursor fx:constant="HAND" />
               </cursor></Button>

                <Button fx:id="viewInboxButton" style="-fx-background-color: #FFFFE0;" text="View Inbox">
               <font>
                  <Font name="Arial" size="15.0" />
               </font>
               <cursor>
                  <Cursor fx:constant="HAND" />
               </cursor></Button>

            </HBox>

        </VBox>
    </center>

</BorderPane>
