<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.Cursor?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Hyperlink?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.PasswordField?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.StackPane?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.text.Font?>

<BorderPane xmlns="http://javafx.com/javafx/25" xmlns:fx="http://javafx.com/fxml/1" fx:controller="org.quantum_safe.client_quantum.Controller.LoginController">

    <center>
        <StackPane prefHeight="630.0" prefWidth="946.0" style="-fx-background-color: linear-gradient(to bottom right, #f3e8ff, #e9d8fd);" BorderPane.alignment="TOP_CENTER">

            <VBox alignment="CENTER" maxWidth="600" spacing="50.0">

                <!-- TITLE -->
                <Label alignment="TOP_CENTER" contentDisplay="TOP" prefHeight="74.0" prefWidth="588.0" text="Quantum Safe Messenger" textFill="#3e217b">
                    <font>
                        <Font name="Arial" size="42" />
                    </font>
                </Label>

                <!-- LOGIN CARD -->
                <VBox alignment="CENTER" fillWidth="true" spacing="25.0" style="-fx-background-color: #FFFFE0; -fx-background-radius: 30; -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.25), 20,0,0,8);">

                    <!-- CARD HEADER -->
                    <Label alignment="CENTER" maxWidth="Infinity" prefWidth="499.0" style="-fx-background-radius: 25; -fx-background-color: linear-gradient(to right, #8a6fd1, #9370DB); -fx-padding: 18;" text="Login To Your Account">
                        <font>
                            <Font name="Arial" size="24" />
                        </font>
                    </Label>

                    <TextField fx:id="emailField" maxWidth="500.0" promptText="Enter Your Email" style="-fx-background-radius: 25;                                   -fx-padding: 12;" />

                    <PasswordField fx:id="passwordField" maxWidth="500.0" promptText="Enter Your Password" style="-fx-background-radius: 25;                                       -fx-padding: 12;" />

                    <Button fx:id="loginButton" maxHeight="50.0" maxWidth="100.0" style="-fx-background-color: linear-gradient(to right, #8a6fd1, #9370DB); -fx-text-fill: white; -fx-background-radius: 25;" text="Login">
                        <font>
                            <Font name="Arial" size="15" />
                        </font>
                  <cursor>
                     <Cursor fx:constant="HAND" />
                  </cursor>
                    </Button>
               <padding>
                  <Insets bottom="20.0" />
               </padding>

                </VBox>

                <!-- REGISTER -->
                <Hyperlink fx:id="registerLink" text="Don't Have an Account? Register." textFill="#3e217b">
                    <font>
                        <Font name="Arial" size="15" />
                    </font>
                </Hyperlink>

            </VBox>

        </StackPane>
    </center>
</BorderPane>
